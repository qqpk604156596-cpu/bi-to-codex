	partition FactSalesLine = m
		mode: import
		source =
				let
					Source = MySQL.Database(MySqlServer, MySqlDatabase, [ReturnSingleDatabase = true]),
					Navigation = Source{[Schema=MySqlDatabase, Item="vw_fact_sales_line"]}[Data],
					Typed = Table.TransformColumnTypes(Navigation, {{"SourceRowId", type text}, {"InvoiceNo", type text}, {"StockCode", type text}, {"Description", type text}, {"Quantity", Int64.Type}, {"InvoiceDate", type datetime}, {"UnitPrice", type number}, {"CustomerID", type text}, {"Country", type text}, {"IsCancellation", type logical}, {"UnknownCustomer", type logical}, {"ZeroPrice", type logical}, {"LineAmount", type number}}),
					WithDate = Table.AddColumn(Typed, "InvoiceDateDate", each DateTime.Date([InvoiceDate]), type date),
					WithCustomerKey = Table.AddColumn(WithDate, "CustomerKey", each if [CustomerID] = null then "UNKNOWN" else [CustomerID], type text)
				in
					WithCustomerKey
