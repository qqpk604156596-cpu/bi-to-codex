table FactSalesLine
	lineageTag: 0972f7df-8dce-405a-adc3-aaddb0f598bd

	measure 'Gross Sales' = CALCULATE ( SUM ( FactSalesLine[LineAmount] ), FactSalesLine[IsCancellation] = FALSE (), FactSalesLine[Quantity] > 0, FactSalesLine[UnitPrice] > 0 )
		formatString: £#,0.00
		lineageTag: 7452278d-787d-48a8-8bd3-db222a355283

	measure 'Cancelled Sales' = CALCULATE ( SUMX ( FactSalesLine, ABS ( FactSalesLine[LineAmount] ) ), FactSalesLine[IsCancellation] = TRUE () )
		formatString: £#,0.00
		lineageTag: de100118-d2c6-4a5c-8e73-bfabe7980edf

	measure 'Net Sales' = SUM ( FactSalesLine[LineAmount] )
		formatString: £#,0.00
		lineageTag: 39951f44-aa14-4b01-ae7d-304d04e00adc

	measure 'Order Count' = CALCULATE ( DISTINCTCOUNT ( FactSalesLine[InvoiceNo] ), FactSalesLine[IsCancellation] = FALSE (), FactSalesLine[Quantity] > 0, FactSalesLine[UnitPrice] > 0 )
		formatString: 0
		lineageTag: 51f1fb45-1d34-4fe9-a1e8-ea67ac831d36

	measure 'Units Sold' = CALCULATE ( SUM ( FactSalesLine[Quantity] ), FactSalesLine[IsCancellation] = FALSE (), FactSalesLine[Quantity] > 0, FactSalesLine[UnitPrice] > 0 )
		formatString: 0
		lineageTag: c3020aea-0530-471d-a8dc-7c9352699aaf

	measure 'Active Customers' = CALCULATE ( DISTINCTCOUNT ( FactSalesLine[CustomerID] ), FactSalesLine[IsCancellation] = FALSE (), FactSalesLine[Quantity] > 0, FactSalesLine[UnitPrice] > 0, NOT ISBLANK ( FactSalesLine[CustomerID] ) )
		formatString: 0
		lineageTag: 3d80707b-4b7b-4128-89df-4d49d5e9f9a7

	measure 'Average Order Value' = DIVIDE ( [Gross Sales], [Order Count] )
		formatString: £#,0.00
		lineageTag: c13fa631-b921-4af7-adc6-bb5cb562eb07

	measure 'Cancelled Invoice Count' = CALCULATE ( DISTINCTCOUNT ( FactSalesLine[InvoiceNo] ), FactSalesLine[IsCancellation] = TRUE () )
		isHidden
		lineageTag: 543810c2-7ea0-442b-837b-0a671278325d

	measure 'All Invoice Count' = DISTINCTCOUNT ( FactSalesLine[InvoiceNo] )
		isHidden
		lineageTag: 68bc3f6f-6531-4626-8be7-1b69394e3a0a

	measure 'Cancellation Rate' = DIVIDE ( [Cancelled Invoice Count], [All Invoice Count] )
		formatString: 0.00%
		lineageTag: e33d6c69-0102-4400-84f0-cf25d76eacad

	measure 'Sales MoM %' =
			VAR IsSingleMonth = HASONEVALUE ( DimDate[YearMonth] )
			VAR PreviousSales = CALCULATE ( [Net Sales], DATEADD ( DimDate[Date], -1, MONTH ) )
			RETURN IF ( NOT IsSingleMonth || ISBLANK ( PreviousSales ) || PreviousSales = 0, BLANK (), DIVIDE ( [Net Sales] - PreviousSales, PreviousSales ) )
		formatString: 0.00%
		lineageTag: fbbeeb9e-fa73-4734-b68c-0bbea1ab4b17

	measure 'Sales YoY %' =
			VAR IsSingleMonth = HASONEVALUE ( DimDate[YearMonth] )
			VAR PriorYearSales = CALCULATE ( [Net Sales], DATEADD ( DimDate[Date], -1, YEAR ) )
			RETURN IF ( NOT IsSingleMonth || ISBLANK ( PriorYearSales ) || PriorYearSales = 0, BLANK (), DIVIDE ( [Net Sales] - PriorYearSales, PriorYearSales ) )
		formatString: 0.00%
		lineageTag: 4bd41aee-a6e2-4ff7-8a47-7615c14c24e8

